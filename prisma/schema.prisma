generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "mds"]
}

// ─── public：应用账户与用户态 JSON（Prisma 管理）────────────────────────────

model User {
  id               String    @id
  username         String    @unique
  email            String?
  phone            String?   @unique
  emailVerifiedAt  DateTime?
  passHash         String
  passSalt         String
  role             String
  /// standard=普通用户，pro=付费 Pro 用户
  plan             String    @default("standard")
  createdAt        DateTime

  sessions              Session[]
  assetTemplateState    UserAssetTemplateState?
  macroChartPrefsRow    UserMacroChartPrefs?
  bookmarkState         UserBookmarkState?
  marketEventsCreated   MarketEvent[]

  @@schema("public")
}

model Session {
  token     String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime
  expiresAt DateTime

  @@index([userId])
  @@schema("public")
}

model PendingRegistration {
  token     String   @id
  username  String
  email     String
  phone     String
  passHash  String
  passSalt  String
  createdAt DateTime
  expiresAt DateTime

  @@index([email])
  @@index([phone])
  @@schema("public")
}

/// Full `TemplateState` JSON (version 1 + templates + activeTemplateId)
model UserAssetTemplateState {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  state  Json

  @@schema("public")
}

/// Full `MacroChartPrefs` JSON
model UserMacroChartPrefs {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  prefs  Json

  @@schema("public")
}

/// Full `BookmarkState` JSON（常用链接 / 收藏夹）
model UserBookmarkState {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  state  Json

  @@schema("public")
}

/// 系统内置宏观模板覆盖（管理员保存）；全局单例 id=default
model SystemMacroChartPrefs {
  id        String   @id @default("default")
  prefs     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@schema("public")
}

/// 宏观指标目录树布局（管理员编辑）；全局单例 id=default
model MacroCatalogLayout {
  id        String   @id @default("default")
  layout    Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("macro_catalog_layout")
  @@schema("public")
}

/// 数据调度：经济日历关键词覆盖（FRED 键或发布包 id）；优先于代码内置表与 `.data/*.json`
model DataSchedulerCalendarOverride {
  key       String   @id @db.VarChar(80)
  /// `fred` | `package`
  kind      String   @default("fred") @db.VarChar(16)
  spec      Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("data_scheduler_calendar_override")
  @@schema("public")
}

enum EventImportance {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@schema("public")
}

enum EventDatePrecision {
  DATE
  DATETIME

  @@schema("public")
}

/// 宏观/行情联动事件记录
model MarketEvent {
  id            String             @id @default(uuid())
  title         String?            @db.VarChar(256)
  content       String             @db.Text
  occurredAt    DateTime           @map("occurred_at")
  datePrecision EventDatePrecision @default(DATE) @map("date_precision")
  importance    EventImportance    @default(MEDIUM)
  eventType     String?            @map("event_type") @db.VarChar(64)
  countries     String[]           @default([])
  industries    String[]           @default([])
  assets        String[]           @default([])
  macroKeys     String[]           @default([]) @map("macro_keys")
  sourceUrl     String?            @map("source_url") @db.VarChar(512)
  isPublic      Boolean            @default(true) @map("is_public")
  createdById   String             @map("created_by_id")
  createdBy     User               @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@index([occurredAt(sort: Desc)])
  @@index([importance])
  @@map("market_event")
  @@schema("public")
}

/// AI 周度市场观察（Automation ingest + 站内阅读）
model WeeklyReport {
  id           String   @id @default(uuid())
  weekEnding   DateTime @unique @map("week_ending") @db.Date
  meta         Json
  bodyMarkdown String   @map("body_markdown") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([weekEnding(sort: Desc)])
  @@map("weekly_report")
  @@schema("public")
}

/// 单股月度/周期经营状态 AI 分析（外部 Automation ingest）
model CompanyOperatingBrief {
  id           String   @id @default(uuid())
  symbol       String   @db.VarChar(16)
  periodMonth  String   @map("period_month") @db.VarChar(7)
  meta         Json
  bodyMarkdown String   @map("body_markdown") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([symbol, periodMonth])
  @@index([periodMonth(sort: Desc)])
  @@index([symbol])
  @@map("company_operating_brief")
  @@schema("public")
}

/// 同行业经营叙事互证（外部 Automation ingest）
model IndustryPeerResonance {
  id           String   @id @default(uuid())
  peerGroupId  String   @map("peer_group_id") @db.VarChar(128)
  periodMonth  String   @map("period_month") @db.VarChar(7)
  payload      Json
  bodyMarkdown String   @map("body_markdown") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([peerGroupId, periodMonth])
  @@index([periodMonth(sort: Desc)])
  @@map("industry_peer_resonance")
  @@schema("public")
}

// ─── mds：统一金融数据目录（宏观 / 资产 / 行情），与厂商无关 ─────────────────

enum InstrumentKind {
  MACRO_SERIES
  CRYPTO_SPOT
  EQUITY
  INDEX_SPOT
  FX
  COMMODITY
  OTHER

  @@schema("mds")
}

/// 宏观或业务主题分类树（自洽编码，不绑定外部终端）。
model MacroCategory {
  id        String          @id @default(uuid()) @db.Uuid
  /// 稳定业务编码，API / 配置引用（非外部厂商 ID）
  code      String          @unique @db.VarChar(48)
  name      String
  parentId  String?         @map("parent_id") @db.Uuid
  parent    MacroCategory?  @relation("MacroCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  MacroCategory[] @relation("MacroCategoryTree")
  sortOrder Int             @default(0) @map("sort_order")
  metadata  Json?

  instruments Instrument[]

  @@index([parentId])
  @@schema("mds")
}

/// 统一「序列 / 标的」：宏观序列、交易品种等；主引用为 `id` 与 `code`。
model Instrument {
  id           String       @id @default(uuid()) @db.Uuid
  code         String       @unique @db.VarChar(48)
  kind         InstrumentKind
  name         String
  /// Excel「指标英文名称」或人工维护的英文展示名
  nameEn       String?      @map("name_en")
  shortName    String?      @map("short_name")
  description  String?
  freqLabel    String?      @map("freq_label")
  unit         String?
  categoryId   String?      @map("category_id") @db.Uuid
  category     MacroCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  fredSeriesId String?      @unique @map("fred_series_id") @db.VarChar(64)
  exchange     String?      @db.VarChar(32)
  tickerSymbol String?      @map("ticker_symbol") @db.VarChar(64)
  externalRefs Json?        @map("external_refs")
  metadata     Json?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  macroPoints      MacroObservation[]
  bars             Bar[]
  dataSubscription DataSubscription?
  releasePackageMembers ReleasePackageMember[]

  @@index([kind])
  @@index([categoryId])
  @@index([exchange, tickerSymbol])
  @@schema("mds")
}

/// 宏观等指标型观测（窄表）；历史宽表可经 ETL 写入此处。
model MacroObservation {
  id           String     @id @default(uuid()) @db.Uuid
  instrumentId String     @map("instrument_id") @db.Uuid
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  obsDate      DateTime   @map("obs_date") @db.Date
  value        Float

  @@unique([instrumentId, obsDate])
  @@index([instrumentId, obsDate])
  @@schema("mds")
}

model Bar {
  id           String     @id @default(uuid()) @db.Uuid
  instrumentId String     @map("instrument_id") @db.Uuid
  instrument   Instrument @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  timeframe    String     @db.VarChar(16)
  openedAt     DateTime   @map("opened_at")
  open         Float
  high         Float
  low          Float
  close        Float
  volume       Float      @default(0)

  @@unique([instrumentId, timeframe, openedAt])
  @@index([instrumentId, timeframe, openedAt])
  @@schema("mds")
}

// ─── mds：按计划更新的数据订阅（多国统计机构 → 数据源 → 序列）────────────────

/// 国家统计/央行等发布机构（业务主体，与具体 API 连接器解耦）。
model StatisticalAgency {
  id          String   @id @db.VarChar(48)
  countryCode String   @map("country_code") @db.VarChar(2)
  nameZh      String   @map("name_zh") @db.VarChar(128)
  nameEn      String?  @map("name_en") @db.VarChar(128)
  websiteUrl  String?  @map("website_url") @db.VarChar(512)
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sources DataSource[]

  releasePackages ReleasePackage[]

  @@index([countryCode])
  @@map("statistical_agency")
  @@schema("mds")
}

enum SourceAdapterKind {
  FRED_API
  WORLD_BANK_API
  REST_API
  BULK_FILE
  MANUAL

  @@schema("mds")
}

enum DataFetchMethod {
  API
  BULK_DOWNLOAD
  MANUAL

  @@schema("mds")
}

enum DataGranularity {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUAL
  IRREGULAR

  @@schema("mds")
}

/// 技术数据源（API / 文件等），可挂接到 StatisticalAgency。
model DataSource {
  id          String            @id @db.VarChar(48)
  agencyId    String?           @map("agency_id") @db.VarChar(48)
  agency      StatisticalAgency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  name        String            @db.VarChar(128)
  adapterKind SourceAdapterKind @map("adapter_kind")
  baseUrl     String?           @map("base_url") @db.VarChar(512)
  termsUrl    String?           @map("terms_url") @db.VarChar(512)
  /// 如 { "requestsPerMinute": 60, "minIntervalMs": 500 }
  rateLimit   Json?             @map("rate_limit")
  metadata    Json?
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  subscriptions DataSubscription[]

  @@index([agencyId])
  @@map("data_source")
  @@schema("mds")
}

/// 单条 Instrument 的更新订阅：官方序列键、粒度、发布规则、下次运行时间。
model DataSubscription {
  id              String          @id @default(uuid()) @db.Uuid
  instrumentId    String          @unique @map("instrument_id") @db.Uuid
  instrument      Instrument      @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  sourceId        String          @map("source_id") @db.VarChar(48)
  source          DataSource      @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  /// 源内序列标识，如 FRED series_id、世行 indicator id
  sourceSeriesKey String          @map("source_series_key") @db.VarChar(128)
  fetchMethod     DataFetchMethod @map("fetch_method")
  granularity     DataGranularity
  timezone        String          @default("UTC") @db.VarChar(64)
  /// ReleaseRule JSON，见 src/lib/data/scheduler/releaseRule.ts
  releaseRule     Json            @map("release_rule")
  /// 增量拉取时向前覆盖的月数（宏观修订）
  revisionLookback Int            @default(3) @map("revision_lookback")
  nextRunAt       DateTime?       @map("next_run_at")
  lastSuccessAt   DateTime?       @map("last_success_at")
  lastObsDate     DateTime?       @map("last_obs_date") @db.Date
  enabled         Boolean         @default(true)
  priority        Int             @default(0)
  retryCount      Int             @default(0) @map("retry_count")
  lastError       String?         @map("last_error") @db.Text
  releasePackageId String?        @map("release_package_id") @db.VarChar(64)
  releasePackage   ReleasePackage? @relation(fields: [releasePackageId], references: [id], onDelete: SetNull)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  fetchRuns FetchRun[]

  @@index([sourceId])
  @@index([enabled, nextRunAt])
  @@index([releasePackageId])
  @@map("data_subscription")
  @@schema("mds")
}

/// 按官方发布包（报告）对齐经济日历；包内指标共享 scheduleState / nextRunAt。
model ReleasePackage {
  id              String          @id @db.VarChar(64)
  labelZh         String          @map("label_zh") @db.VarChar(128)
  labelEn         String?         @map("label_en") @db.VarChar(128)
  countryCode     String          @map("country_code") @db.VarChar(2)
  agencyId        String?         @map("agency_id") @db.VarChar(48)
  agency          StatisticalAgency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  granularity     DataGranularity
  /// CalendarMatchSpec JSON
  calendarSpec    Json            @map("calendar_spec")
  /// economic_calendar 模板（不含 calendarMatch / calendarSync）
  releaseTemplate Json            @map("release_template")
  /// ReleasePackageScheduleState JSON
  scheduleState   Json?           @map("schedule_state")
  nextRunAt       DateTime?       @map("next_run_at")
  enabled         Boolean         @default(true)
  sortOrder       Int             @default(0) @map("sort_order")
  metadata        Json?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  members       ReleasePackageMember[]
  subscriptions DataSubscription[]

  @@index([countryCode])
  @@index([enabled, nextRunAt])
  @@map("release_package")
  @@schema("mds")
}

/// Instrument ↔ ReleasePackage（每仪器最多归属一个包）
model ReleasePackageMember {
  id           String         @id @default(uuid()) @db.Uuid
  packageId    String         @map("package_id") @db.VarChar(64)
  package      ReleasePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  instrumentId String         @map("instrument_id") @db.Uuid
  instrument   Instrument     @relation(fields: [instrumentId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now()) @map("created_at")

  @@unique([packageId, instrumentId])
  @@unique([instrumentId])
  @@index([packageId])
  @@map("release_package_member")
  @@schema("mds")
}

enum FetchRunStatus {
  SUCCESS
  PARTIAL
  FAILED
  SKIPPED

  @@schema("mds")
}

/// 单次拉取执行日志。
model FetchRun {
  id             String         @id @default(uuid()) @db.Uuid
  subscriptionId String         @map("subscription_id") @db.Uuid
  subscription   DataSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  startedAt      DateTime       @map("started_at")
  finishedAt     DateTime?      @map("finished_at")
  status         FetchRunStatus
  rowsUpserted   Int            @default(0) @map("rows_upserted")
  rowsSkipped    Int            @default(0) @map("rows_skipped")
  error          String?        @db.Text
  /// 源端最新 obs 与库内 lastObsDate 相差天数（粗算滞后）
  sourceLagDays  Int?           @map("source_lag_days")
  metadata       Json?
  createdAt      DateTime       @default(now()) @map("created_at")

  @@index([subscriptionId, startedAt])
  @@map("fetch_run")
  @@schema("mds")
}

/// 美股证券主数据（GICS + 市值缓存）
model EquitySecurity {
  id              String    @id @default(uuid()) @db.Uuid
  symbol          String    @unique @db.VarChar(16)
  cik             String?   @db.VarChar(16)
  name            String    @db.VarChar(256)
  gicsSector        String    @map("gics_sector") @db.VarChar(64)
  gicsIndustryGroup String?   @map("gics_industry_group") @db.VarChar(128)
  gicsIndustry      String?   @map("gics_industry") @db.VarChar(128)
  gicsSubIndustry   String?   @map("gics_sub_industry") @db.VarChar(128)
  gicsIndustryCode  String?   @map("gics_industry_code") @db.VarChar(16)
  marketCap       Float?    @map("market_cap")
  marketCapAsOf   DateTime? @map("market_cap_as_of") @db.Date
  irUrl           String?   @map("ir_url") @db.VarChar(512)
  website         String?   @db.VarChar(512)
  metadata        Json?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([gicsSector])
  @@index([gicsSector, gicsIndustry])
  @@index([gicsIndustryCode])
  @@index([marketCap(sort: Desc)])
  @@map("equity_security")
  @@schema("mds")
}

/// 指数成分快照（如 SP500）
model IndexConstituent {
  id        String   @id @default(uuid()) @db.Uuid
  indexCode String   @map("index_code") @db.VarChar(32)
  symbol    String   @db.VarChar(16)
  asOfDate  DateTime @map("as_of_date") @db.Date
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([indexCode, symbol, asOfDate])
  @@index([indexCode, asOfDate])
  @@index([symbol])
  @@map("index_constituent")
  @@schema("mds")
}

/// 个股财报快照（主源 SEC EDGAR companyfacts，供行业聚合与个股基本面）。
/// periodType=FY：年报（period 形如 "2024FY"，另有兼容别名 "TTM"）；
/// periodType=Q：季度（period 为财报期末所在日历季度，形如 "2025Q1"）。
/// 三大报表标准化字段：利润表 revenue/grossMargin/opMargin/netIncome/eps，
/// 资产负债表 totalAssets/totalLiabilities/equity/longTermDebt/cash/sharesOutstanding，
/// 现金流量表 ocf/capex/dividendsPaid。
model EquityFundamentalSnapshot {
  id                String    @id @default(uuid()) @db.Uuid
  symbol            String    @db.VarChar(16)
  period            String    @db.VarChar(16)
  periodType        String    @default("FY") @map("period_type") @db.VarChar(8)
  revenue           Float?
  revenueYoY        Float?    @map("revenue_yoy")
  eps               Float?
  epsYoY            Float?    @map("eps_yoy")
  grossMargin       Float?    @map("gross_margin")
  opMargin          Float?    @map("op_margin")
  pe                Float?
  netIncome         Float?    @map("net_income")
  ocf               Float?
  capex             Float?
  totalAssets       Float?    @map("total_assets")
  totalLiabilities  Float?    @map("total_liabilities")
  equity            Float?
  longTermDebt      Float?    @map("long_term_debt")
  cash              Float?
  sharesOutstanding Float?    @map("shares_outstanding")
  dividendsPaid     Float?    @map("dividends_paid")
  /// 财报期实际截止日（period 是标准化标签，此列保留公司真实财季末）
  fiscalDate        DateTime? @map("fiscal_date") @db.Date
  /// 财季位置 1–4（由 10-K 年度期末锚定；年度聚合按 FQ4 分组）
  fiscalQuarter     Int?      @map("fiscal_quarter") @db.SmallInt
  asOf              DateTime  @map("as_of") @db.Date
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@unique([symbol, period])
  @@index([symbol])
  @@index([asOf])
  @@index([symbol, periodType, asOf])
  @@map("equity_fundamental_snapshot")
  @@schema("mds")
}

/// 拆股事件（Yahoo chart events.splits；exDate 当日价格已为拆后刻度）
model EquitySplit {
  id          String   @id @default(uuid()) @db.Uuid
  symbol      String   @db.VarChar(16)
  exDate      DateTime @map("ex_date") @db.Date
  /// N 拆 1 → ratio = N（numerator/denominator）
  ratio       Float
  numerator   Float
  denominator Float
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([symbol, exDate])
  @@index([symbol, exDate])
  @@map("equity_split")
  @@schema("mds")
}

/// 每标的日线覆盖范围与回补状态（取代进程内 TTL Map）
model EquityPriceCoverage {
  symbol        String    @id @db.VarChar(16)
  firstDate     DateTime? @map("first_date") @db.Date
  lastDate      DateTime? @map("last_date") @db.Date
  /// 已按 range=max 拉过全量历史（此后只做尾部增量）
  fullHistory   Boolean   @default(false) @map("full_history")
  lastCheckedAt DateTime? @map("last_checked_at")
  /// 远端确认无此标的（如已退市/拼写错误），避免反复打 Yahoo
  notFound      Boolean   @default(false) @map("not_found")
  source        String?   @db.VarChar(16)
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("equity_price_coverage")
  @@schema("mds")
}

/// 美股个股/ETF 日线（Yahoo 回补缓存）。
/// OHLCV 为 Yahoo quote 口径：已按拆股回溯调整、未含现金分红；adjClose 含拆股+分红。
/// 三种复权由 priceAdjustment.ts 结合 EquitySplit 精确还原，不做启发式猜测。
model EquityDailyBar {
  id       String   @id @default(uuid()) @db.Uuid
  symbol   String   @db.VarChar(16)
  date     DateTime @db.Date
  open     Float?
  high     Float?
  low      Float?
  close    Float
  adjClose Float    @map("adj_close")
  volume   Float?
  source   String   @db.VarChar(16)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([symbol, date])
  @@index([symbol, date(sort: Desc)])
  @@map("equity_daily_bar")
  @@schema("mds")
}

/// SEC EDGAR 披露索引（供 Automation 取证）
model SecFiling {
  id        String   @id @default(uuid()) @db.Uuid
  cik       String   @db.VarChar(16)
  symbol    String?  @db.VarChar(16)
  accession String   @db.VarChar(32)
  form      String   @db.VarChar(16)
  filedAt   DateTime @map("filed_at") @db.Date
  url       String   @db.VarChar(512)
  /// 8-K item 编号原样存（如 "2.02,9.01"），事件时间线据此分级
  items     String?  @db.VarChar(64)
  /// EDGAR 主文档文件名（直链 …/{accessionNoDash}/{primaryDocument}）
  primaryDocument       String? @map("primary_document") @db.VarChar(256)
  primaryDocDescription String? @map("primary_doc_description") @db.VarChar(256)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([cik, accession])
  @@index([symbol, filedAt(sort: Desc)])
  @@index([cik, filedAt(sort: Desc)])
  @@index([form])
  @@map("sec_filing")
  @@schema("mds")
}
