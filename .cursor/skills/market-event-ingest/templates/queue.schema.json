{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MarketEventIngestQueue",
  "type": "object",
  "required": ["version", "windowFrom", "windowTo", "tasks"],
  "properties": {
    "version": { "const": 1 },
    "description": { "type": "string" },
    "windowFrom": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "windowTo": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "updatedAt": { "type": "string" },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "mode", "priority", "status", "query"],
        "properties": {
          "id": { "type": "string" },
          "mode": { "type": "string" },
          "priority": { "type": "number" },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "done", "blocked"]
          },
          "query": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "country": { "type": "string" },
              "symbol": { "type": "string" },
              "assets": { "type": "array", "items": { "type": "string" } },
              "industries": { "type": "array", "items": { "type": "string" } },
              "tags": { "type": "array", "items": { "type": "string" } }
            }
          },
          "outputFile": { "type": "string" },
          "notes": { "type": "string" },
          "gicsSector": { "type": "string" },
          "year": { "type": "integer" }
        }
      }
    }
  }
}
