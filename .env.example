# 复制为 .env.local 后填写（不要提交 .env.local）

# K 线调查日志：设为 1 时服务端终端也输出 [KLINE-DEBUG]（浏览器 dev 默认已开；另可 localStorage KLINE_DEBUG=1）
# KLINE_DEBUG=1

# PostgreSQL（Prisma）。本机与阿里云统一约定：用户 finance / 库 finance / 表 owner=finance
# 示例：postgresql://finance:postgres@127.0.0.1:5432/finance
# Prisma CLI（migrate / studio）通过 npm 脚本加载 .env.local；勿删 DATABASE_URL。
DATABASE_URL=

# 迁移完成后用户与模板数据以数据库为准；旧的 `.data/*.json` 可归档（见 `.data/archived-after-postgres-migration/`）。

# 区间回报工具（/markets-tools）一次性 xlsx 导入目录；运行时读 mds.bar，不读 xlsx
# ASSET_DATA_DIR=

# 一次性：将 MySQL 库 `h` 迁入同一 Postgres 的 schema `h`（需本机 MariaDB/MySQL 已导入 dump）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=h

# 统一金融目录 schema `mds`。若曾导入 legacy schema `h`，可并入 mds：
# npm run db:seed-mds-from-legacy-h
# 宽表 → 窄表（默认月频 Data_M，可加参数）：
# npm run db:etl-legacy-h-observations
# npm run db:etl-legacy-h-observations -- --granularity=daily
# npm run db:etl-legacy-h-observations -- --dry-run
# 上游 API 根地址，例如 https://api.provider.com
UPSTREAM_API_BASE=

# 若上游需要 Bearer Token，可在此配置（仅服务端 Route Handler 可读）
UPSTREAM_API_KEY=

# 美联储 FRED 宏观 API（免费注册）：https://fred.stlouisfed.org/docs/api/api_key.html
# 统一宏观默认走 FRED；数据调度 worker 必需
FRED_API_KEY=

# 内置模板的 fred: 序列默认「读库优先」（已入库观测直接读本地 PG，不请求 FRED；缺失才实时回退）
# 设为 0 可整体回退为纯实时（旧行为）。留空/其它值 = 开启（推荐）
# MACRO_FRED_DB_FIRST=1

# TradingEconomics 经济日历（npm run data:sync-calendar）— 抓取公开页面，无需 API Key
# 默认页：https://tradingeconomics.com/calendar
# TRADINGECONOMICS_CALENDAR_PAGE=https://tradingeconomics.com/calendar
# 若页面时间非 UTC：TE_CALENDAR_UTC_OFFSET_HOURS=0
# 若返回空/403：浏览器打开日历页后复制 Cookie
# TE_CALENDAR_COOKIE=
# 向前匹配发布事件的窗口天数（默认 90；原 21 天对季频/远月发布过短）
# TE_CALENDAR_WINDOW_DAYS=90
# 模拟浏览器时间范围：5=本月、6=下月（默认 5,6；勿用 Recent/0，SSR 仅约一周）
# TE_CALENDAR_RANGE_PRESETS=5,6
# 日历未匹配时，距下次 sync-calendar 重试的小时数（不触发数据拉取，默认 24）
# TE_CALENDAR_RESYNC_HOURS=24
# TRADINGECONOMICS_USER_AGENT=

# （已废弃）Investing.com 经济日历 — 请勿再使用
# INVESTING_CALENDAR_COOKIE=

# Phase 4：Overview xlsx 定时重导（npm run data:seed-phase4 / data:worker --source=overview-china）
# CHINA_OVERVIEW_XLSX_PATH=
# JAPAN_OVERVIEW_XLSX_PATH=
# DATA_LAG_DAYS_THRESHOLD=14
# DATA_LAG_ALERT_EMAIL=
# DATA_LAG_WEBHOOK_URL=
# DATA_LAG_ALERT_AFTER_WORKER=1

# Phase 5：e-Stat 日本 / Slack 告警
# ESTAT_APP_ID=
# DATA_LAG_ALERT_COOLDOWN_HOURS=24
# DATA_LAG_SLACK_WEBHOOK_URL=

# Financial Modeling Prep（行情页副图 TTM PE、美股行业 sector performance / profile / 财报）；https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
# 免费/基础档 FMP 要求 limit≤5；勿超过 5，否则 HTTP 402
# FMP_QUARTERLY_LIMIT=5

# 美股 K 线 / 日线行情：Yahoo Finance v8 chart（免密钥，覆盖全部美股，自动落库 mds.equity_daily_bar）。
# 无需任何配置。复权（前/后/不复权）由服务端按拆股事件 + 现金分红精确计算。

# SEC EDGAR User-Agent（符号联想 company_tickers + 基本面 companyfacts 用；SEC 要求自定义 UA）
# SEC 要求 UA 带真实联系邮箱，localhost/example.com 等会被 403 拒绝（导致美股联想失效）
# SEC_EDGAR_USER_AGENT=finance-site/1.0 (contact: real-name@your-real-domain.com)

# 用户与注册邮件
# 应用外网地址（用于生成邮箱确认链接），例如 http://localhost:3000
APP_BASE_URL=http://localhost:3000

# SMTP（若不填则验证链接写入 .data/mail-outbox.log 便于本地调试）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 初始管理员（首次启动生成）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456

# AI 周度观察自动化写入（POST /api/weekly-reports，Bearer 或 X-Weekly-Ingest-Token）
# WEEKLY_REPORT_INGEST_TOKEN=
# 美股经营简报 / 同业互证 ingest（优先 EQUITY_INGEST_TOKEN；未设则回退 WEEKLY_REPORT_INGEST_TOKEN）
# EQUITY_INGEST_TOKEN=
