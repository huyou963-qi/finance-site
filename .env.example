# 复制为 .env.local 后填写（不要提交 .env.local）

# K 线调查日志：设为 1 时服务端终端也输出 [KLINE-DEBUG]（浏览器 dev 默认已开；另可 localStorage KLINE_DEBUG=1）
# KLINE_DEBUG=1

# PostgreSQL（Prisma）。示例：postgresql://postgres:postgres@localhost:5432/postgres
# Prisma CLI（migrate / studio）通过 npm 脚本加载 .env.local；勿删 DATABASE_URL。
DATABASE_URL=

# 迁移完成后用户与模板数据以数据库为准；旧的 `.data/*.json` 可归档（见 `.data/archived-after-postgres-migration/`）。

# 一次性：将 MySQL 库 `h` 迁入同一 Postgres 的 schema `h`（需本机 MariaDB/MySQL 已导入 dump）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=h

# 统一金融目录 schema `mds`。若曾导入 legacy schema `h`，可并入 mds：
# npm run db:seed-mds-from-legacy-h
# 宽表 → 窄表（默认月频 Data_M，可加参数）：
# npm run db:etl-legacy-h-observations
# npm run db:etl-legacy-h-observations -- --granularity=daily
# npm run db:etl-legacy-h-observations -- --dry-run
# 上游 API 根地址，例如 https://api.provider.com
UPSTREAM_API_BASE=

# 若上游需要 Bearer Token，可在此配置（仅服务端 Route Handler 可读）
UPSTREAM_API_KEY=

# 美联储 FRED 宏观 API（免费注册）：https://fred.stlouisfed.org/docs/api/api_key.html
# 统一宏观默认走 FRED
FRED_API_KEY=

# Financial Modeling Prep（行情页副图 TTM PE、宏观 fmp: 指标）；https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=
# 免费/基础档 FMP 要求 limit≤5；勿超过 5，否则 HTTP 402
# FMP_QUARTERLY_LIMIT=5

# Interactive Brokers — 全站 IB 功能二选一（K 线 / 持仓 / 成交 / 联想搜索）
# IBKR_API_MODE=cp   全部走 Client Portal Gateway（HTTPS + Cookie，见下方）
# IBKR_API_MODE=tws   全部走 TWS / IB Gateway Socket API（见下方，无需 Gateway Cookie）
IBKR_API_MODE=cp

# —— 仅 IBKR_API_MODE=tws 时填写 ——
# 先在 TWS：配置 → API → 设置 → 启用 Socket、记下端口（常见 7496）
IBKR_TWS_HOST=127.0.0.1
IBKR_TWS_PORT=7496
IBKR_TWS_CLIENT_ID=1
# 可选：TWS 模式下连续期货 MGC=F 向左翻页时，若同时开着 Gateway 并配置下方 Cookie，
# 会用 CP secdef 解析历史交割月 conid（避免 TWS 200「未找到证券定义」）

# —— 仅 IBKR_API_MODE=cp 时填写 ——
# 文档：https://www.interactivebrokers.com/campus/ibkr-api-page/cpapi-v1/
# 教程多为 https://localhost:5000；若浏览器登录的是其他端口（如 5099）请改成你的 Gateway 根 URL（不要带 /v1/api）
IBKR_CP_BASE_URL=https://localhost:5000
# 可选：Cookie（教程代码可不写；本站服务端若 401 再配）
# IBKR_CP_COOKIE=
# 可选：Cookie 文件路径（默认 .data/ibkr-cp-cookie.txt）。开发时可用 /api/ibkr/setup-cookie 粘贴保存
# IBKR_CP_COOKIE_FILE=
# 生产如需开放「网页写 Cookie」接口，设为 1；或设 IBKR_CP_SETUP_TOKEN 并用请求头 X-IBKR-Setup-Token
# IBKR_CP_ALLOW_SETUP=
# IBKR_CP_SETUP_TOKEN=
# TLS：连接 localhost/127.0.0.1 时默认等同 verify=False；若要强制校验本机证书设为 0；若要强制跳过（远程 Gateway）设为 1
# IBKR_CP_INSECURE_TLS=
# 可选：自建 HTTP 桥（返回 JSON 与 /api/data/klines 一致），设置后不走 Gateway REST。示例：http://127.0.0.1:8765
# IBKR_BRIDGE_URL=

# 用户与注册邮件
# 应用外网地址（用于生成邮箱确认链接），例如 http://localhost:3000
APP_BASE_URL=http://localhost:3000

# SMTP（若不填则验证链接写入 .data/mail-outbox.log 便于本地调试）
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# 初始管理员（首次启动生成）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123456
